# .env file
LLM_API_KEY=sk-8e21ff289bd8477db35719a290f7a7f0
LLM_MODEL_ID=deepseek-v4-flash
LLM_BASE_URL=https://api.deepseek.com
LLM_API_FORMAT=chat_completions
SERPAPI_API_KEY=5d288f9a4b76d19cd277d1fe7d05352f4411406f2da420c789b6dbfd9981e3ab

TRACE_ENABLED=false

# 或使用本地Qdrant (需要Docker)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=myagent_vectors
QDRANT_VECTOR_SIZE=1024
QDRANT_DISTANCE=cosine
QDRANT_TIMEOUT=30

# Neo4j 图数据库配置
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=Neo4j@123456
NEO4J_DATABASE=neo4j
NEO4J_MAX_CONNECTION_LIFETIME=3600
NEO4J_MAX_CONNECTION_POOL_SIZE=50
NEO4J_CONNECTION_TIMEOUT=60

# ==========================
# 嵌入（Embedding）配置 - OpenAI 兼容 REST（vLLM）
# ==========================
EMBED_MODEL_NAME=bge-m3
EMBED_API_KEY=not-needed
EMBED_BASE_URL=http://localhost:8000/v1

# ==========================
# ffmpeg 路径（pydub/markitdown 音频处理用，目录指向 bin 的父目录）
# ==========================
FFMPEG_PATH=D:\Devpkg\ffmpeg\ffmpeg-n4.4.5-gpl-amd64-shared\bin\ffmpeg.exe
